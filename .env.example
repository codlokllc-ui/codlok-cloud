DATABASE_URL="file:./db/custom.db"

# Configure these securely in the deployment platform. Never commit real values.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
CODLOK_JOB_RUNNER_SECRET=
# Deployment classification used to isolate durable Configuration records.
CODELOK_ENVIRONMENT=development

# Required in production. Generate a random 64-character hexadecimal key.
CODELOK_CONFIG_MASTER_KEY=
