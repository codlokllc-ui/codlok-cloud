DATABASE_URL=file:/home/z/my-project/db/custom.db

# Codlok Cloud — Auth Module (Phase 1)
# Per Master Spec §3.7, provider credentials are not auto-created. Two options:
#   1) Set CODELOK_AUTH_USE_MOCK=true for the demo / local dev (uses MockAuthAdapter).
#   2) Provide real Supabase credentials (SUPABASE_URL, SUPABASE_ANON_KEY,
#      SUPABASE_SERVICE_ROLE_KEY) to use SupabaseAuthAdapter in production.
CODELOK_AUTH_USE_MOCK=true
CODELOK_APP_BASE_URL=http://localhost:3000
